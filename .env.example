# ─────────────────────────────────────────────────────────────────────
# OpenX — environment variables (example)
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Add your key on the SHIVANSHAI_API_KEY line below.
#
# SECURITY:
#   • Your real .env is gitignored — it is NEVER pushed to GitHub.
#   • On Vercel, set these as (secret) Environment Variables instead.
#
# The chat stores history in the browser, so NO database is required.
# ─────────────────────────────────────────────────────────────────────

# ShivanshAI engine API key (REQUIRED for live AI replies).
SHIVANSHAI_API_KEY="your-key-here"
SHIVANSHAI_API_URL="https://integrate.api.nvidia.com/v1"

# PostgreSQL (OPTIONAL — only for the /api/health DB check).
# DATABASE_URL="postgresql://user:pass@host:5432/app_db"
